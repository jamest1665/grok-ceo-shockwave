# GROK-CEO Configuration
# Copy to .env and fill in

XAI_API_KEY=sk-proj-...your-xai-key...

# Agent behavior
APPROVE_THRESHOLD=0.88
DRY_RUN=true          # Set false to enable real actions (use with caution + sandbox)
SANDBOX=true

# Limits
MAX_USD_PER_CYCLE=0.10
MAX_TOKENS_PER_CYCLE=8000
TICK_INTERVAL=15

# Paths
DB_PATH=.lancedb
LOG_PATH=logs/audit.log
GIT_REPO_PATH=.